{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/reconcile.js": {
      "maxDuration": 300
    },
    "api/recompute-category.js": {
      "maxDuration": 120
    },
    "api/archive-completed.js": {
      "maxDuration": 120
    }
  }
}
